# ============================================================
# Node / 前端构建
# ============================================================
node_modules/
dist/
dist-ssr/
*.local

# 前端构建缓存
.vite/
.turbo/

# ============================================================
# Rust / Tauri 构建
# ============================================================
/src-tauri/target/
/src-tauri/gen/schemas/
/src-tauri/WixTools*/

# Cargo 本地覆盖
.cargo/config.toml
Cargo.lock.bak

# ============================================================
# 打包产物（复制到项目根目录的 exe/dmg 不入库）
# ============================================================
/*.exe
/*.msi
/*.dmg
/*.app

# ============================================================
# 日志
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# 环境与密钥（永远不要入库）
# ============================================================
.env
.env.*
!.env.example
*.key
*.pem
*.pfx

# ============================================================
# 编辑器 / IDE
# ============================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
*.user

# ============================================================
# 操作系统缓存
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================================
# 项目本地临时文件
# ============================================================
tmp/
temp/
.tmp/
*.tmp

# 用户本地测试素材（照片 / 签名）— 避免误入库
/samples/
/test-photos/
/test-signatures/

# Claude Code 本地状态（不共享给协作者）
.claude/
