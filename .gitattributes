# 统一换行符为 LF，避免 Windows/macOS 之间 CRLF 反复变动。
# 二进制文件显式标记，防止 Git 把它当文本处理。

# 默认：文本文件用 LF
* text=auto eol=lf

# 源码 —— 强制 LF
*.rs        text eol=lf
*.toml      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf

# Windows 专属脚本 —— 保留 CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# 二进制文件 —— 不做换行符处理
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.exe       binary
*.dll       binary
*.msi       binary
*.dmg       binary
*.zip       binary
*.tar.gz    binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
